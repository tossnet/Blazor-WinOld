@page "/"

@inject IDialogService DialogService
@inject IJSRuntime JS

<PageTitle>Home</PageTitle>

<div class="hero" style="background-color: @GetBackgroundColor();">
    <div class="hero-text">
        <div class="hero-badge-row">
            <a href="https://www.nuget.org/packages/BlazorWinOld/" target="_blank" tabindex="-1">
                <img src="https://img.shields.io/nuget/v/BlazorWinOld.svg" alt="NuGet" />
            </a>
            <a href="https://www.nuget.org/packages/BlazorWinOld/" target="_blank" tabindex="-1">
                <img src="https://img.shields.io/nuget/dt/BlazorWinOld" alt="Downloads" />
            </a>
            <a href="https://github.com/tossnet/Blazor-WinOld/blob/master/LICENSE.txt" target="_blank" tabindex="-1">
                <img src="https://img.shields.io/github/license/tossnet/Blazor-WinOld?color=594ae2&amp;logo=github&amp;style=flat-square" alt="License" />
            </a>
        </div>
        <h1 class="hero-title">Blazor <span class="hero-title-accent">WinOld</span></h1>
        <p class="hero-subtitle">
            Nostalgic Windows UI components for Blazor.<br />
            Authentic styles from Windows 98, XP, 7 and 10.
        </p>
        <div class="hero-install">
            <code class="hero-install-code">dotnet add package BlazorWinOld</code>
            <button class="hero-copy-btn" @onclick="CopyInstallCommand" title="Copy to clipboard">
                @(_copied ? "✓" : "⧉")
            </button>
        </div>
        <div class="hero-features">
            <span class="hero-feature-pill">🪶 ~260 KB</span>
            <span class="hero-feature-pill">⚡ Server &amp; WASM</span>
            <span class="hero-feature-pill">🎨 4 Windows themes</span>
        </div>
    </div>
    <WinOldWindow Appearance="appearance" 
                  Title="Live Preview" class="hero-preview">
        <div style="padding:6px;">
            <div class="hero-theme-selector light">
                @foreach (var theme in _themes)
                {
                    <button class="@ThemeBtnClass(theme.Value)"
                            @onclick="() => appearance = theme.Value">
                        @theme.Label
                    </button>
                }
            </div>
            <WinOldFrame Appearance="appearance">
                <WinOldTextBox Appearance="appearance" Label="Username :" @bind-Value="_previewUsername" />
                <WinOldCheckBox Appearance="appearance" Label="Remember me" @bind-Value="_previewChecked" />
                <div style="display:flex; gap:6px; margin-top:6px;">
                    <WinOldButton Appearance="appearance" Default>OK</WinOldButton>
                    <WinOldButton Appearance="appearance">Cancel</WinOldButton>
                </div>
            </WinOldFrame>
        </div>
    </WinOldWindow>
</div>


<WinOldCheckBox Appearance="appearance"
                Label="Disable components :"
                CheckedChanged="@disabledComponents" />

<WinOldFrame Appearance="appearance"
             Label="Frame"
             Disabled="_disabledComponents">


    <WinOldTextBox Appearance="appearance"
                   Label="Textbox :"
                   @bind-Value="SelectRadioString" />

    <WinOldLabel Appearance="appearance">
        Label : @SelectedRadio.ToString()
    </WinOldLabel>

    <WinOldButton OnClick="OpenDialog"
                  Appearance="appearance"
                  Default="true" >Open a dialogbox</WinOldButton>

    <WinOldOptionButtonGroup T="int"
                             @bind-Value="SelectedRadio"
                             Appearance="appearance">
        <WinOldOptionButton Label="Adrien" Value="1" />
        <WinOldOptionButton Label="Christophe" Value="2" />
        <WinOldOptionButton Label="Denis" Value="3" />
    </WinOldOptionButtonGroup>
</WinOldFrame>


<WinOldTabs Appearance="appearance"
            Style="margin-top:5px; max-width: 500px">
    <WinOldTabPanel Label="Tab A">
        <p>Contents of first tab</p>
    </WinOldTabPanel>

    <WinOldTabPanel Label="Tab B">
        <p>Contents of second tab</p>
    </WinOldTabPanel>
    <WinOldTabPanel Label="MessageBox" IsDefault="true">
        <div style="display:flex;gap: 10px;">
            <WinOldFrame Appearance="appearance"
                         Label="Icon"
                         Disabled="_disabledComponents"
                         Style="flex: 1;">

                <WinOldOptionButtonGroup T="Icon"
                                         @bind-Value="iconMessage"
                                         Appearance="appearance">
                    <WinOldOptionButton Label="None" Value="Icon.None" />
                    <WinOldOptionButton Label="Alert" Value="Icon.Alert" />
                    <WinOldOptionButton Label="Critical" Value="Icon.Critical" />
                    <WinOldOptionButton Label="Information" Value="Icon.Information" />
                    <WinOldOptionButton Label="Question" Value="Icon.Question" />
                </WinOldOptionButtonGroup>

            </WinOldFrame>

            <WinOldFrame Appearance="appearance"
                         Label="Buttons"
                         Disabled="_disabledComponents"
                         Style="flex: 1;">

                <WinOldTextBox Appearance="appearance"
                               Label="Message title :"
                               @bind-Value="MessageTitle"
                               Style="padding-bottom:4px" />
		
                <WinOldTextBox Appearance="appearance"
                               Label="Name of OK Button :"
                               @bind-Value="ButtonNameOK"
                               Style="padding-bottom:4px" />
			
                <WinOldTextBox Appearance="appearance"
                               Label="Name of Cancel Button :"
                               @bind-Value="ButtonNameCancel"
                               Style="padding-bottom:4px" />
            </WinOldFrame>
        </div>

        <div style="margin-top:6px;display: flex;justify-content: center;">
            <WinOldButton OnClick="ClickMe"
                          Appearance="appearance">Show MessageBox</WinOldButton>
        </div>
    </WinOldTabPanel>

</WinOldTabs>


@code {
    private bool _disabledComponents;
    private bool _copied;
    private string _previewUsername = "Christophe";
    private bool _previewChecked;

    private readonly (string Label, Appearance Value)[] _themes =
    [
        ("Win 98", Appearance.Win98),
        ("Win XP", Appearance.WinXP),
        ("Win 7",  Appearance.Win7),
        ("Win 10", Appearance.Win10),
    ];

    private int SelectedRadio { get; set; } = 2;
    private string SelectRadioString { get; set; } = "Christophe";

    private Appearance appearance { get; set; } = Appearance.WinXP;
    private Icon iconMessage { get; set; } = Icon.Information;
	 
    private string MessageTitle { get; set; } = "Title";
    private string ButtonNameOK { get; set; } = "OK";
    private string ButtonNameCancel { get; set; } = "";

    async Task ClickMe()
    {
        Console.WriteLine("Clicked!");

        var options = new MessageBoxOptions
        {
            Appearance = appearance,
            Title = MessageTitle,
            Message = "Blazor is awesome!",
            Icon = iconMessage,
            OkButtonText = ButtonNameOK,
            CancelButtonText = ButtonNameCancel
        };
        var DialogResult = await DialogService.ShowMessageBox(options);
    }

    private void disabledComponents(bool value) => _disabledComponents = !_disabledComponents;

    private string ThemeBtnClass(Appearance value) =>
        appearance == value ? "hero-theme-btn active" : "hero-theme-btn";

    private bool IsDesktopLight() => appearance is Appearance.Win7 or Appearance.Win10;

    private string GetDesktopColor()
    {
        SystemColors.Appearance = appearance;
        var color = SystemColors.Desktop;
        return $"rgb({color.R}, {color.G}, {color.B})";
    }

    private string GetBackgroundColor()
    {
        SystemColors.Appearance = appearance;
        var color = SystemColors.Desktop;
        return $"rgb({color.R}, {color.G}, {color.B})";
    }

    private async Task CopyInstallCommand()
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", "dotnet add package BlazorWinOld");
        _copied = true;
        await Task.Delay(2000);
        _copied = false;
    }

    private async Task OpenDialog()
    {
        bool? result = await DialogService.ShowDialog(new DialogOptions
        {
            Title = "Settings",
            Width = "300px",
            Height = "400px",
            Appearance = appearance,
            OkButtonText = "OK",
            CancelButtonText = "Cancel",
            ChildContent = @<SimpleDialog Appearance="@appearance" />
            });

        if (result == true) { /* OK clicked */ }
    }
}
