@page "/button-page"

<PageTitle>Button</PageTitle>

<h1>Button</h1>

<div style="display:grid; grid-template-columns:repeat(3, auto); gap:5px; width:fit-content;">

    <WinOldButton Appearance="Appearance.DOS">Click me</WinOldButton>

    <WinOldButton Appearance="Appearance.DOS"
			  Disabled>Click me</WinOldButton>
			  
    <WinOldButton Appearance="Appearance.DOS"
			  Default="true">Click me</WinOldButton>

    <WinOldButton Appearance="Appearance.Win98">Click me</WinOldButton>

    <WinOldButton Appearance="Appearance.Win98"
			  Disabled>Click me</WinOldButton>

    <WinOldButton Appearance="Appearance.Win98"
			  Default="true">Click me</WinOldButton>

    <WinOldButton Appearance="Appearance.WinXP">Click me</WinOldButton>

    <WinOldButton Appearance="Appearance.WinXP"
			  Disabled>Click me</WinOldButton>

    <WinOldButton Appearance="Appearance.WinXP"
			  Default="true">Click me</WinOldButton>

    <WinOldButton Appearance="Appearance.Win7">Click me</WinOldButton>

    <WinOldButton Appearance="Appearance.Win7"
			  Disabled>Click me</WinOldButton>

    <WinOldButton Appearance="Appearance.Win7"
			  Default="true">Click me</WinOldButton>

    <WinOldButton Appearance="Appearance.Win10">Click me</WinOldButton>

    <WinOldButton Appearance="Appearance.Win10"
			  Disabled>Click me</WinOldButton>


    <WinOldButton Appearance="Appearance.Win10"
			  Default="true">Click me</WinOldButton>

</div>

<CodeBlock Language="CodeLanguage.Razor"
		   EnableLineNumbers="true"
		   Code=@(@"
<WinOldButton Appearance=""Appearance.WinXP"">Click me</WinOldButton> />

<WinOldButton Appearance=""Appearance.Win98""
		  	  Disabled>Click me</WinOldButton>
		   	 	 ") />

<h2>Event</h2>
<p>OnClick</p>

<h2>Behavior</h2>
<p>Default</p>
<p>Disabled</p>
