@page "/menu-page"

<PageTitle>Menu</PageTitle>

<h1>Menu</h1>

<p>
    The <code>WinOldMenu</code> and <code>WinOldMenuItem</code> components provide a classic Windows-style
    menu bar with support for submenus, separators, disabled items, and keyboard shortcuts, available
    across all supported visual styles.
</p>

<div class="alert alert-info" role="alert">
    <strong>Tip :</strong> <code>WinOldMenu</code> can also be used as a <strong>context menu</strong> (right-click / long press).
    See the <NavLink href="contextmenu-page">Context Menu page</NavLink> for a dedicated example.
</div>

<h2>Examples by Style</h2>

<div style="display:flex; flex-direction: row; gap: 20px; flex-wrap: wrap; align-items: flex-start;">

    <div style="flex:0 0 calc(25% - 20px);">
        <h7>Windows 98</h7>
        <WinOldMenu Appearance="Appearance.Win98">
            <WinOldMenuItem Label="File">
                <WinOldMenuItem Label="New"     IconCssClass="bi bi-emoji-smile-upside-down"  OnClick="@(() => DoAction("New"))" />
                <WinOldMenuItem Label="Open..."   OnClick="@(() => DoAction("Open"))" />
                <WinOldMenuItem Label="Save"      Disabled="true" />
                <WinOldMenuItem IsSeparator />
                <WinOldMenuItem Label="Export"    Disabled />
                <WinOldMenuItem IsSeparator />
                <WinOldMenuItem Label="Exit"      OnClick="@(() => DoAction("Exit"))" />
            </WinOldMenuItem>
            <WinOldMenuItem Label="View">
                <WinOldMenuItem Label="Zoom +"    OnClick="@(() => DoAction("Zoom +"))" />
                <WinOldMenuItem Label="Zoom -"    OnClick="@(() => DoAction("Zoom -"))" />
                <WinOldMenuItem IsSeparator />
                <WinOldMenuItem Label="Disposition">
                    <WinOldMenuItem Label="Classic"  OnClick="@(() => DoAction("Classic"))" />
                    <WinOldMenuItem Label="Compact"  OnClick="@(() => DoAction("Compact"))" />
                    <WinOldMenuItem Label="Étendue"  OnClick="@(() => DoAction("Étendue"))" />
