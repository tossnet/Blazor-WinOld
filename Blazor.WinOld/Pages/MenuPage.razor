<h2>Last Action</h2>
<div style="padding: 10px; background-color: #f5f5f5; border: 1px solid #ccc; margin: 10px 0;">
    <p><strong>Last action:</strong> @_lastAction</p>
</div>

<h2>Code Example</h2>

<CodeBlock Language="CodeLanguage.Razor"
           EnableLineNumbers="true"
           Code=@(@"<WinOldMenu Appearance=""Appearance.Win10"">

    <WinOldMenuItem Label=""File"">
        <WinOldMenuItem Label=""New""     OnClick=""@(() => DoAction(""New""))"" />
        <WinOldMenuItem Label=""Open..."" OnClick=""@(() => DoAction(""Open""))"" />
        <WinOldMenuItem Label=""Save""    Disabled=""true"" />
        <WinOldMenuItem IsSeparator />
        <WinOldMenuItem Label=""Export""  Disabled />
        <WinOldMenuItem IsSeparator />
        <WinOldMenuItem Label=""Exit""    OnClick=""@(() => DoAction(""Exit""))"" />
    </WinOldMenuItem>

    <WinOldMenuItem Label=""View"">
        <WinOldMenuItem Label=""Zoom +""  OnClick=""@(() => DoAction(""Zoom +""))"" />
        <WinOldMenuItem Label=""Zoom -""  OnClick=""@(() => DoAction(""Zoom -""))"" />
        <WinOldMenuItem IsSeparator />
        <WinOldMenuItem Label=""Disposition"">
            <WinOldMenuItem Label=""Classic"" OnClick=""@(() => DoAction(""Classic""))"" />
            <WinOldMenuItem Label=""Compact"" OnClick=""@(() => DoAction(""Compact""))"" />
        </WinOldMenuItem>
    </WinOldMenuItem>

    <WinOldMenuItem Label=""Help"">
        <WinOldMenuItem Label=""About..."" Shortcut=""F1"" OnClick=""@(() => DoAction(""About""))"" />
    </WinOldMenuItem>

</WinOldMenu>

@code {
    private void DoAction(string action) { ... }
}") />

<h2>WinOldMenu Properties</h2>

<div style="margin: 20px 0; border: 1px solid #ccc;">
    <div style="display: flex; flex-wrap: wrap; background-color: #f0f0f0; font-weight: bold; border-bottom: 2px solid #ccc;">
        <div style="flex: 1 1 130px; padding: 8px; min-width: 110px;">Property</div>
        <div style="flex: 1 1 120px; padding: 8px; min-width: 100px;">Type</div>
        <div style="flex: 0 1 90px;  padding: 8px; min-width: 70px;">Default</div>
        <div style="flex: 3 1 200px; padding: 8px; min-width: 180px;">Description</div>
    </div>
    <div style="display: flex; flex-wrap: wrap; border-bottom: 1px solid #eee;">
        <div style="flex: 1 1 130px; padding: 8px; min-width: 110px;"><code>Appearance</code></div>
        <div style="flex: 1 1 120px; padding: 8px; min-width: 100px;">Appearance</div>
        <div style="flex: 0 1 90px;  padding: 8px; min-width: 70px;">Win10</div>
        <div style="flex: 3 1 200px; padding: 8px; min-width: 180px;">Visual style: Win98, WinXP, Win7, Win10</div>
    </div
        <div style="display: flex; flex-wrap: wrap; border-bottom: 1px solid #eee;">
        <div style="flex: 1 1 130px; padding: 8px; min-width: 110px;"><code>IsContextMenu</code></div>
        <div style="flex: 1 1 120px; padding: 8px; min-width: 100px;">bool</div>
        <div style="flex: 0 1 90px;  padding: 8px; min-width: 70px;">false</div>
        <div style="flex: 3 1 200px; padding: 8px; min-width: 180px;">Switches to context menu mode — positioned at the cursor via <code>ShowContextMenu()</code></div>
    </div>
    <div style="display: flex; flex-wrap: wrap; border-bottom: 1px solid #eee;">
        <div style="flex: 1 1 130px; padding: 8px; min-width: 110px;"><code>ChildContent</code></div>
        <div style="flex: 1 1 120px; padding: 8px; min-width: 100px;">RenderFragment?</div>
        <div style="flex: 0 1 90px;  padding: 8px; min-width: 70px;">—</div>
        <div style="flex: 3 1 200px; padding: 8px; min-width: 180px;">Menu items (<code>WinOldMenuItem</code> components)</div>
    </div>
    <div style="display: flex; flex-wrap: wrap; border-bottom: 1px solid #eee;">
        <div style="flex: 1 1 130px; padding: 8px; min-width: 110px;"><code>Disabled</code></div>
        <div style="flex: 1 1 120px; padding: 8px; min-width: 100px;">bool</div>
        <div style="flex: 0 1 90px;  padding: 8px; min-width: 70px;">false</div>
        <div style="flex: 3 1 200px; padding: 8px; min-width: 180px;">Disables all items in the menu</div>
    </div>
    <div style="display: flex; flex-wrap: wrap; border-bottom: 1px solid #eee;">
        <div style="flex: 1 1 130px; padding: 8px; min-width: 110px;"><code>Class</code></div>
        <div style="flex: 1 1 120px; padding: 8px; min-width: 100px;">string?</div>
        <div style="flex: 0 1 90px;  padding: 8px; min-width: 70px;">null</div>
        <div style="flex: 3 1 200px; padding: 8px; min-width: 180px;">Additional CSS class applied to the menu container</div>
    </div>
    <div style="display: flex; flex-wrap: wrap;">
        <div style="flex: 1 1 130px; padding: 8px; min-width: 110px;"><code>Style</code></div>
        <div style="flex: 1 1 120px; padding: 8px; min-width: 100px;">string?</div>
        <div style="flex: 0 1 90px;  padding: 8px; min-width: 70px;">null</div>
        <div style="flex: 3 1 200px; padding: 8px; min-width: 180px;">Inline CSS style applied to the menu container</div>
    </div>
</div>

<h2>WinOldMenuItem Properties</h2>

<div style="margin: 20px 0; border: 1px solid #ccc;">
    <div style="display: flex; flex-wrap: wrap; background-color: #f0f0f0; font-weight: bold; border-bottom: 2px solid #ccc;">
        <div style="flex: 1 1 130px; padding: 8px; min-width: 110px;">Property</div>
        <div style="flex: 1 1 120px; padding: 8px; min-width: 100px;">Type</div>
        <div style="flex: 0 1 90px;  padding: 8px; min-width: 70px;">Default</div>
        <div style="flex: 3 1 200px; padding: 8px; min-width: 180px;">Description</div>
    </div>
    <div style="display: flex; flex-wrap: wrap; border-bottom: 1px solid #eee;">
        <div style="flex: 1 1 130px; padding: 8px; min-width: 110px;"><code>Label</code></div>
        <div style="flex: 1 1 120px; padding: 8px; min-width: 100px;">string</div>
        <div style="flex: 0 1 90px;  padding: 8px; min-width: 70px;">""</div>
        <div style="flex: 3 1 200px; padding: 8px; min-width: 180px;">Text displayed for the menu item</div>
    </div>
    <div style="display: flex; flex-wrap: wrap; border-bottom: 1px solid #eee;">
        <div style="flex: 1 1 130px; padding: 8px; min-width: 110px;"><code>Shortcut</code></div>
        <div style="flex: 1 1 120px; padding: 8px; min-width: 100px;">string?</div>
        <div style="flex: 0 1 90px;  padding: 8px; min-width: 70px;">null</div>
        <div style="flex: 3 1 200px; padding: 8px; min-width: 180px;">Keyboard shortcut hint displayed on the right side of the item (e.g., "Ctrl+S")</div>
    </div>
    <div style="display: flex; flex-wrap: wrap; border-bottom: 1px solid #eee;">
        <div style="flex: 1 1 130px; padding: 8px; min-width: 110px;"><code>IsSeparator</code></div>
        <div style="flex: 1 1 120px; padding: 8px; min-width: 100px;">bool</div>
        <div style="flex: 0 1 90px;  padding: 8px; min-width: 70px;">false</div>
        <div style="flex: 3 1 200px; padding: 8px; min-width: 180px;">Renders a horizontal separator line instead of a clickable item</div>
    </div>
    <div style="display: flex; flex-wrap: wrap; border-bottom: 1px solid #eee;">
        <div style="flex: 1 1 130px; padding: 8px; min-width: 110px;"><code>Disabled</code></div>
        <div style="flex: 1 1 120px; padding: 8px; min-width: 100px;">bool</div>
        <div style="flex: 0 1 90px;  padding: 8px; min-width: 70px;">false</div>
        <div style="flex: 3 1 200px; padding: 8px; min-width: 180px;">Grays out the item and prevents interaction</div>
    </div>
    <div style="display: flex; flex-wrap: wrap; border-bottom: 1px solid #eee;">
        <div style="flex: 1 1 130px; padding: 8px; min-width: 110px;"><code>OnClick</code></div>
        <div style="flex: 1 1 120px; padding: 8px; min-width: 100px;">EventCallback</div>
        <div style="flex: 0 1 90px;  padding: 8px; min-width: 70px;">—</div>
        <div style="flex: 3 1 200px; padding: 8px; min-width: 180px;">Callback invoked when the item is clicked (leaf items only)</div>
    </div>
    <div style="display: flex; flex-wrap: wrap; border-bottom: 1px solid #eee;">
        <div style="flex: 1 1 130px; padding: 8px; min-width: 110px;"><code>ChildContent</code></div>
        <div style="flex: 1 1 120px; padding: 8px; min-width: 100px;">RenderFragment?</div>
        <div style="flex: 0 1 90px;  padding: 8px; min-width: 70px;">—</div>
        <div style="flex: 3 1 200px; padding: 8px; min-width: 180px;">Nested <code>WinOldMenuItem</code> components — turns this item into a submenu parent</div>
    </div>
    <div style="display: flex; flex-wrap: wrap; border-bottom: 1px solid #eee;">
        <div style="flex: 1 1 130px; padding: 8px; min-width: 110px;"><code>Class</code></div>
        <div style="flex: 1 1 120px; padding: 8px; min-width: 100px;">string?</div>
        <div style="flex: 0 1 90px;  padding: 8px; min-width: 70px;">null</div>
        <div style="flex: 3 1 200px; padding: 8px; min-width: 180px;">Additional CSS class applied to the item</div>
    </div>
    <div style="display: flex; flex-wrap: wrap;">
        <div style="flex: 1 1 130px; padding: 8px; min-width: 110px;"><code>Style</code></div>
        <div style="flex: 1 1 120px; padding: 8px; min-width: 100px;">string?</div>
        <div style="flex: 0 1 90px;  padding: 8px; min-width: 70px;">null</div>
        <div style="flex: 3 1 200px; padding: 8px; min-width: 180px;">Inline CSS style applied to the item</div>
    </div>
</div>


@code {
    private string _lastAction = "(nothing)";

    private void DoAction(string action)
    {
        _lastAction = action;
    }
}
