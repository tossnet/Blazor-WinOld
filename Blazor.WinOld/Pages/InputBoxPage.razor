@page "/inputbox-page"


@inject IDialogService DialogService

<PageTitle>InputBox</PageTitle>

<h1>InputBox</h1>

<p>The <code>WinOldInputBox</code> is a modal dialog component that prompts users for input with different vintage Windows styles. It supports text and numeric input types.</p>

<div class="info-block" style="margin-bottom:20px">
	<p>
		⚠️ <strong>Setup Required:</strong> To enable this component, add the <code>&lt;WinOldInputBoxHost /&gt;</code> component
		at the bottom of your <strong>MainLayout.razor</strong>:
	</p>
	<CodeBlock Language="CodeLanguage.Razor"
			   EnableLineNumbers="false"
			   Code=@(@"<WinOldInputBoxHost />") />
</div>

<h2>Text Input Examples</h2>

<p>Click the buttons below to display InputBox dialogs with different Windows styles:</p>

<div style="display:flex; flex-direction: row; gap: 10px; flex-wrap: wrap; margin-bottom: 20px;">
	<WinOldButton OnClick="() => ShowTextInput(Appearance.Win98)"
				  Appearance="Appearance.Win98">
		Windows 98
	</WinOldButton>

	<WinOldButton OnClick="() => ShowTextInput(Appearance.WinXP)"
				  Appearance="Appearance.WinXP">
		Windows XP
	</WinOldButton>

	<WinOldButton OnClick="() => ShowTextInput(Appearance.Win7)"
				  Appearance="Appearance.Win7">
		Windows 7
	</WinOldButton>

	<WinOldButton OnClick="() => ShowTextInput(Appearance.Win10)"
				  Appearance="Appearance.Win10">
		Windows 10
	</WinOldButton>
</div>

<h2>Numeric Input Examples</h2>

<p>InputBox also supports numeric input types with specialized methods:</p>

<div style="display:flex; flex-direction: row; gap: 10px; flex-wrap: wrap; margin-bottom: 20px;">
	<WinOldButton OnClick="ShowIntInput"
				  Appearance="Appearance.Win10">
		Integer Input
	</WinOldButton>

	<WinOldButton OnClick="ShowDecimalInput"
				  Appearance="Appearance.Win10">
		Decimal Input
	</WinOldButton>

	<WinOldButton OnClick="ShowDoubleInput"
				  Appearance="Appearance.Win10">
		Double Input
	</WinOldButton>
</div>

<h2>Current Values</h2>

<div style="padding: 10px; background-color: #f5f5f5; border: 1px solid #ccc; margin: 20px 0;">
	<p><strong>Text Value:</strong> @(_textValue ?? "(null)")</p>
	<p><strong>Integer Value:</strong> @(_intValue?.ToString() ?? "(null)")</p>
	<p><strong>Decimal Value:</strong> @(_decimalValue?.ToString("N2") ?? "(null)")</p>
	<p><strong>Double Value:</strong> @(_doubleValue?.ToString("F4") ?? "(null)")</p>
</div>

<h2>Text Input Code Example</h2>

<CodeBlock Language="CodeLanguage.Razor"
		   EnableLineNumbers="true"
		   Code=@(@"
@inject IDialogService DialogService

<WinOldButton OnClick=""ShowTextInput""
			  Appearance=""Appearance.Win10"">
			 Show InputBox
</WinOldButton>") />

<CodeBlock Language="CodeLanguage.CSharp"
		   EnableLineNumbers="true"
		   Code=@(@"
private string? _textValue = ""my default value"";

private async Task ShowTextInput(Appearance appearance)
{
	var options = new InputBoxOptions
	{
		Appearance = appearance,
		Title = ""Enter Your Name"",
		Message = ""Please enter your name:"",
		Value = _textValue,
		OkButtonText = ""OK"",
		CancelButtonText = ""Cancel""
	};
	_textValue = await DialogService.ShowInputBox(options);
}") />

<h2>Numeric Input Code Examples</h2>

<h3>Integer Input</h3>

<CodeBlock Language="CodeLanguage.CSharp"
		   EnableLineNumbers="true"
		   Code=@(@"
private int? _intValue = 42;

private async Task ShowIntInput()
{
	var options = new InputBoxOptions
	{
		Appearance = Appearance.Win10,
		Title = ""Enter Age"",
		Message = ""Please enter your age:"",
		Value = _intValue?.ToString(),
		Min = ""0"",
		Max = ""120"",
		Step = ""1"",
		OkButtonText = ""OK"",
		CancelButtonText = ""Cancel""
	};
	_intValue = await DialogService.ShowInputBox<int?>(options);
}") />

