<h2>InputBoxOptions Properties</h2>

<table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
	<thead>
		<tr style="background-color: #f0f0f0; border: 1px solid #ccc;">
			<th style="padding: 8px; border: 1px solid #ccc; text-align: left;">Property</th>
			<th style="padding: 8px; border: 1px solid #ccc; text-align: left;">Type</th>
			<th style="padding: 8px; border: 1px solid #ccc; text-align: left;">Description</th>
		</tr>
	</thead>
	<tbody>
		<tr style="border: 1px solid #ccc;">
			<td style="padding: 8px; border: 1px solid #ccc;"><code>Appearance</code></td>
			<td style="padding: 8px; border: 1px solid #ccc;">Appearance</td>
			<td style="padding: 8px; border: 1px solid #ccc;">Visual style (Win98, WinXP, Win7, Win10)</td>
		</tr>
		<tr style="border: 1px solid #ccc;">
			<td style="padding: 8px; border: 1px solid #ccc;"><code>Title</code></td>
			<td style="padding: 8px; border: 1px solid #ccc;">string</td>
			<td style="padding: 8px; border: 1px solid #ccc;">Title bar text of the dialog</td>
		</tr>
		<tr style="border: 1px solid #ccc;">
			<td style="padding: 8px; border: 1px solid #ccc;"><code>Message</code></td>
			<td style="padding: 8px; border: 1px solid #ccc;">string</td>
			<td style="padding: 8px; border: 1px solid #ccc;">Message displayed to the user</td>
		</tr>
		<tr style="border: 1px solid #ccc;">
			<td style="padding: 8px; border: 1px solid #ccc;"><code>Value</code></td>
			<td style="padding: 8px; border: 1px solid #ccc;">string?</td>
			<td style="padding: 8px; border: 1px solid #ccc;">Initial/default value in the input field</td>
		</tr>
		<tr style="border: 1px solid #ccc;">
			<td style="padding: 8px; border: 1px solid #ccc;"><code>OkButtonText</code></td>
			<td style="padding: 8px; border: 1px solid #ccc;">string</td>
			<td style="padding: 8px; border: 1px solid #ccc;">Text for the OK/confirmation button (default: "OK")</td>
		</tr>
		<tr style="border: 1px solid #ccc;">
			<td style="padding: 8px; border: 1px solid #ccc;"><code>CancelButtonText</code></td>
			<td style="padding: 8px; border: 1px solid #ccc;">string</td>
			<td style="padding: 8px; border: 1px solid #ccc;">Text for the Cancel button (default: "Cancel")</td>
		</tr>
		<tr style="border: 1px solid #ccc;">
			<td style="padding: 8px; border: 1px solid #ccc;"><code>InputType</code></td>
			<td style="padding: 8px; border: 1px solid #ccc;">InputBoxType</td>
			<td style="padding: 8px; border: 1px solid #ccc;">Type of input (Text, Integer, Decimal, Double)</td>
		</tr>
		<tr style="border: 1px solid #ccc;">
			<td style="padding: 8px; border: 1px solid #ccc;"><code>Min</code></td>
			<td style="padding: 8px; border: 1px solid #ccc;">string?</td>
			<td style="padding: 8px; border: 1px solid #ccc;">Minimum value (for numeric inputs)</td>
		</tr>
		<tr style="border: 1px solid #ccc;">
			<td style="padding: 8px; border: 1px solid #ccc;"><code>Max</code></td>
			<td style="padding: 8px; border: 1px solid #ccc;">string?</td>
			<td style="padding: 8px; border: 1px solid #ccc;">Maximum value (for numeric inputs)</td>
		</tr>
		<tr style="border: 1px solid #ccc;">
			<td style="padding: 8px; border: 1px solid #ccc;"><code>Step</code></td>
			<td style="padding: 8px; border: 1px solid #ccc;">string?</td>
			<td style="padding: 8px; border: 1px solid #ccc;">Step increment (for numeric inputs)</td>
		</tr>
	</tbody>
</table>

<h2>Available Methods</h2>

<table style="width: 100%; border-collapse: collapse; margin: 20px 0;">
	<thead>
		<tr style="background-color: #f0f0f0; border: 1px solid #ccc;">
			<th style="padding: 8px; border: 1px solid #ccc; text-align: left;">Method</th>
			<th style="padding: 8px; border: 1px solid #ccc; text-align: left;">Return Type</th>
			<th style="padding: 8px; border: 1px solid #ccc; text-align: left;">Description</th>
		</tr>
	</thead>
	<tbody>
		<tr style="border: 1px solid #ccc;">
			<td style="padding: 8px; border: 1px solid #ccc;"><code>ShowInputBox&lt;T&gt;(options)</code></td>
			<td style="padding: 8px; border: 1px solid #ccc;">Task&lt;T?&gt;</td>
			<td style="padding: 8px; border: 1px solid #ccc;">Generic method that automatically detects InputType based on T (string, int?, decimal?, or double?)</td>
		</tr>
		<tr style="border: 1px solid #ccc;">
			<td style="padding: 8px; border: 1px solid #ccc;"><code>ShowInputBox(options)</code></td>
			<td style="padding: 8px; border: 1px solid #ccc;">Task&lt;string?&gt;</td>
			<td style="padding: 8px; border: 1px solid #ccc;">Shortcut for text input (equivalent to ShowInputBox&lt;string&gt;)</td>
		</tr>
	</tbody>
</table>

<h2>API Usage</h2>

<p>Use the generic <code>ShowInputBox&lt;T&gt;</code> method to handle different input types:</p>

<CodeBlock Language="CodeLanguage.CSharp"
		   EnableLineNumbers="true"
		   Code=@(@"
// String input (you can also use ShowInputBox without type parameter)
var text = await DialogService.ShowInputBox<string>(options);
// or simply:
var text = await DialogService.ShowInputBox(options);

// Integer input
var number = await DialogService.ShowInputBox<int?>(options);

// Decimal input
var price = await DialogService.ShowInputBox<decimal?>(options);

// Double input
var measurement = await DialogService.ShowInputBox<double?>(options);") />

<h2>Return Values</h2>

<ul>
	<li>Returns the entered value when the user clicks <strong>OK</strong></li>
	<li>Returns <code>null</code> when the user clicks <strong>Cancel</strong> or closes the dialog</li>
	<li>For numeric methods, returns <code>null</code> if the input cannot be parsed</li>
</ul>

@code {
	private string? _textValue = "my default value";
	private int? _intValue = 42;
	private decimal? _decimalValue = 99.99m;
	private double? _doubleValue = 3.14159;

	private async Task ShowTextInput(Appearance appearance)
	{
		var options = new InputBoxOptions
		{
			Appearance = appearance,
			Title = "Enter Your Name",
			Message = "Please enter your name:",
			Value = _textValue,
			OkButtonText = "OK",
			CancelButtonText = "Cancel"
		};
		_textValue = await DialogService.ShowInputBox(options);
	}

	private async Task ShowIntInput()
	{
		var options = new InputBoxOptions
		{
			Appearance = Appearance.Win10,
			Title = "Enter Age",
			Message = "Please enter your age:",
			Value = _intValue, 
			Min = "0",
			Max = "120",
			Step = "1",
			OkButtonText = "OK",
			CancelButtonText = "Cancel"
		};
		_intValue = await DialogService.ShowInputBox<int?>(options);
	}

	private async Task ShowDecimalInput()
	{
		var options = new InputBoxOptions
		{
			Appearance = Appearance.Win10,
			Title = "Enter Price",
			Message = "Please enter the price:",
			Value = _decimalValue,
			Min = "0",
			Max = "10000",
			Step = "0.01",
			OkButtonText = "OK",
			CancelButtonText = "Cancel"
		};
		_decimalValue = await DialogService.ShowInputBox<decimal?>(options);
	}

	private async Task ShowDoubleInput()
	{
		var options = new InputBoxOptions
		{
			Appearance = Appearance.Win10,
			Title = "Enter Measurement",
			Message = "Please enter a measurement:",
			Value = _doubleValue,
			Min = "0",
			Max = "1000",
			Step = "0.0001",
			OkButtonText = "OK",
			CancelButtonText = "Cancel"
		};
		_doubleValue = await DialogService.ShowInputBox<double?>(options);
	}
}
