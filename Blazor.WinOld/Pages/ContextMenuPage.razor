@page "/contextmenu-page"

<PageTitle>Context Menu</PageTitle>

<h1>Context Menu</h1>

<div class="alert alert-info" role="alert">
    <strong>Note:</strong> The context menu is not a separate component — it is simply a particular use of the <code>WinOldMenu</code> component via the <code>IsContextMenu="true"</code> property.
</div>

<h2 id="context-menu">Context Menu</h2>

<p>
    Setting <code>IsContextMenu="true"</code> on <code>WinOldMenu</code> switches it to context menu mode.
    Use <code>@@ref</code> to get a reference, then call <code>ShowContextMenu(MouseEventArgs)</code>
    from any mouse event handler — <code>@@oncontextmenu</code> (right-click, also handles OS-swapped
    left-handed buttons), <code>@@onclick</code> (left-click), or both simultaneously.
    On touch devices, use <code>StartLongPress</code> / <code>CancelLongPress</code>.
</p>

<div class="alert alert-secondary" role="alert">
    <strong>Icons :</strong> <code>WinOldMenuItem</code> supports <code>IconCssClass</code> and <code>IconTemplate</code> in context menus exactly as in regular menus.
    See the <NavLink href="menu-page">Menu page</NavLink> for details and live examples.
</div>

<div @oncontextmenu="e => _ctxMenu!.ShowContextMenu(e)"
     @oncontextmenu:preventDefault
     @ontouchstart="e => _ctxMenu!.StartLongPress(e)"
     @ontouchend="() => _ctxMenu!.CancelLongPress()"
     @ontouchmove="() => _ctxMenu!.CancelLongPress()"
     style="width:100%; height:150px; display:flex; flex-direction:column; align-items:center; justify-content:center; border: 1px dashed gray; gap:8px; user-select:none;">
    <span>Right-click / Long press anywhere in this area</span>
    <strong>Last action: @_lastAction</strong>
</div>
<WinOldMenu IsContextMenu="true" @ref="_ctxMenu" Appearance="Appearance.Win10">
    <WinOldMenuItem Label="Cut" OnClick="@(() => DoAction("Cut"))" />
    <WinOldMenuItem Label="Copy" OnClick="@(() => DoAction("Copy"))" />
    <WinOldMenuItem Label="Paste" IconCssClass="bi bi-clipboard" OnClick="@(() => DoAction("Paste"))" />
    <WinOldMenuItem IsSeparator />
    <WinOldMenuItem Label="Send to">
        <WinOldMenuItem Label="Desktop" OnClick="@(() => DoAction("Desktop"))" />
        <WinOldMenuItem Label="Documents" OnClick="@(() => DoAction("Documents"))" />
    </WinOldMenuItem>
</WinOldMenu>

<h3>Code Example</h3>

<CodeBlock Language="CodeLanguage.Razor"
           EnableLineNumbers="true"
           Code=@(@"<div @oncontextmenu=""e => _ctxMenu!.ShowContextMenu(e)""
         @oncontextmenu:preventDefault
         @ontouchstart=""e => _ctxMenu!.StartLongPress(e)""
         @ontouchend=""() => _ctxMenu!.CancelLongPress()""
         @ontouchmove=""() => _ctxMenu!.CancelLongPress()""
         style=""..."">
        Right-click here
    </div>

    <WinOldMenu IsContextMenu=""true"" @ref=""_ctxMenu"" Appearance=""Appearance.Win98"">
        <WinOldMenuItem Label=""Cut""   OnClick=""@(() => DoAction(""Cut""))"" />
        <WinOldMenuItem Label=""Copy""  OnClick=""@(() => DoAction(""Copy""))"" />
        <WinOldMenuItem Label=""Paste"" OnClick=""@(() => DoAction(""Paste""))"" />
        <WinOldMenuItem IsSeparator />
        <WinOldMenuItem Label=""Send to"">
            <WinOldMenuItem Label=""Desktop""   OnClick=""@(() => DoAction(""Desktop""))"" />
            <WinOldMenuItem Label=""Documents"" OnClick=""@(() => DoAction(""Documents""))"" />
        </WinOldMenuItem>
    </WinOldMenu>

    @code {
        private WinOldMenu? _ctxMenu;
    }") />


<h2 id="multiple-context-menus">Multiple context menus</h2>

<p>
    When several <code>WinOldMenu IsContextMenu="true"</code> coexist on the same page,
    opening one automatically closes any previously open menu.
    This behaviour is built-in — no extra setup required beyond <code>AddWinOldComponents()</code>.
</p>

<div style="display:flex; gap:16px;">
    <div @oncontextmenu="e => _ctxMenu2!.ShowContextMenu(e)"
         @oncontextmenu:preventDefault
         @ontouchstart="e => _ctxMenu2!.StartLongPress(e)"
         @ontouchend="() => _ctxMenu2!.CancelLongPress()"
         @ontouchmove="() => _ctxMenu2!.CancelLongPress()"
         style="flex:1; height:120px; display:flex; align-items:center; justify-content:center; border:1px dashed gray; user-select:none;">
        Zone A — right-click
    </div>
    <div @oncontextmenu="e => _ctxMenu3!.ShowContextMenu(e)"
         @oncontextmenu:preventDefault
         @ontouchstart="e => _ctxMenu3!.StartLongPress(e)"
         @ontouchend="() => _ctxMenu3!.CancelLongPress()"
         @ontouchmove="() => _ctxMenu3!.CancelLongPress()"
         style="flex:1; height:120px; display:flex; align-items:center; justify-content:center; border:1px dashed gray; user-select:none;">
        Zone B — right-click
    </div>
</div>
<WinOldMenu IsContextMenu="true" @ref="_ctxMenu2" Appearance="Appearance.Win10">
    <WinOldMenuItem Label="Action A1" OnClick="@(() => DoAction("A1"))" />
    <WinOldMenuItem Label="Action A2" OnClick="@(() => DoAction("A2"))" />
</WinOldMenu>
<WinOldMenu IsContextMenu="true" @ref="_ctxMenu3" Appearance="Appearance.Win10">
    <WinOldMenuItem Label="Action B1" OnClick="@(() => DoAction("B1"))" />
    <WinOldMenuItem Label="Action B2" OnClick="@(() => DoAction("B2"))" />
</WinOldMenu>

<h3>Call from code-behind</h3>

<p>
    You can also call <code>ShowContextMenu</code> from any C# code, not just mouse event handlers.
    For example, you could show the context menu in response to a keyboard shortcut or some other UI action.</p>

<CodeBlock Language="CodeLanguage.CSharp"
           EnableLineNumbers="true"
           Code=@(@"private WinOldMenu? _ctxMenu;

// Appel depuis un code-behind sans MouseEventArgs :
void OpenMenu()
{
    _ctxMenu!.ShowContextMenu(clientX: 100, clientY: 200);
}") />;


@code {
    private WinOldMenu? _ctxMenu;
    private WinOldMenu? _ctxMenu2;
    private WinOldMenu? _ctxMenu3;
    private string _lastAction = "(nothing)";

    private void DoAction(string action)
    {
        _lastAction = action;
    }
}