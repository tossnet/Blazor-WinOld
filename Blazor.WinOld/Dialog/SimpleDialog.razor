<WinOldMenu Appearance="Appearance">

    <WinOldMenuItem Label="File">
        <WinOldMenuItem Label="New" OnClick="@(() => DoAction("New"))" />
        <WinOldMenuItem Label="Open..."  />
        <WinOldMenuItem Label="Save" Disabled="true" />
        <WinOldMenuItem IsSeparator />
        <WinOldMenuItem Label="Export" Disabled />
        <WinOldMenuItem IsSeparator />
        <WinOldMenuItem Label="Exit"  />
    </WinOldMenuItem>
        

    <WinOldMenuItem Label="Help">
        <WinOldMenuItem Label="Documentation"  />
        <WinOldMenuItem Label="About..."  />
    </WinOldMenuItem>

</WinOldMenu>

<WinOldTabs Appearance="Appearance"
			Style="min-width: 210px; height: 100%; margin-left:3px; margin-right: 3px">
	<WinOldTabPanel Label="General" IsDefault="true" Style="height:245px">
		<p>Contents of first tab</p>
        <div @oncontextmenu="e => _ctxMenu!.ShowContextMenu(e)"
             @oncontextmenu:preventDefault
             @ontouchstart="e => _ctxMenu!.StartLongPress(e)"
             @ontouchend="() => _ctxMenu!.CancelLongPress()"
             @ontouchmove="() => _ctxMenu!.CancelLongPress()"
             style="width:100%; height:150px; display:flex; flex-direction:column; align-items:center; justify-content:center; border: 1px dashed gray; gap:8px; user-select:none;">
            <span>Right-click / Long press anywhere in this area</span>
            <strong>Last action: @_lastAction</strong>
        </div>

        <WinOldMenu IsContextMenu="true" @ref="_ctxMenu" Appearance="Appearance">
            <WinOldMenuItem Label="Cut" OnClick="@(() => DoAction("Cut"))" />
            <WinOldMenuItem Label="Copy" OnClick="@(() => DoAction("Copy"))" />
            <WinOldMenuItem Label="Paste" OnClick="@(() => DoAction("Paste"))" />
            <WinOldMenuItem IsSeparator />
            <WinOldMenuItem Label="Send to">
                <WinOldMenuItem Label="Desktop" OnClick="@(() => DoAction("Desktop"))" />
                <WinOldMenuItem Label="Documents" OnClick="@(() => DoAction("Documents"))" />
            </WinOldMenuItem>
        </WinOldMenu>
	</WinOldTabPanel>

	<WinOldTabPanel Label="View" Style="height:245px">
        <img src="\2019-03-18-mvp-summit.jpg" alt="microsoft mvp summit 2019" />
	</WinOldTabPanel>

	<WinOldTabPanel Label="Settings" Style="height:245px">
		<p>Contents of third tab</p>
	</WinOldTabPanel>

</WinOldTabs>

@code {
    [Parameter]
    public Appearance Appearance { get; set; }

    private WinOldMenu? _ctxMenu;
    private string _lastAction = "(nothing)";

    private void DoAction(string action)
    {
        _lastAction = action;
    }
}