@namespace Blazor.WinOld.Components

@inherits WinOldComponentBase

<CascadingValue Value="this" IsFixed="true">
    <ul role="listbox"
        aria-label="@Label"
        class="list-win @GetComponentClass() @Class"
        style="@Style"
        @attributes="Attributes">
        @ChildContent
    </ul>
</CascadingValue>