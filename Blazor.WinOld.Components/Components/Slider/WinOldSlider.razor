@namespace Blazor.WinOld.Components
@typeparam TValue

@inherits WinOldComponentBase

<div style="display: flex; align-items: center; gap: 0.5rem">
    <label class="label-txt-win @GetComponentLabelClass()"
           disabled="@(ParentDisabled | Disabled)">
           @LowLabel
    </label>
    <input type="range"
           class="sld-win @GetComponentClass() @Class"
           min="@FormatInvariant(Min)"
           max="@FormatInvariant(Max)"
           step="@FormatInvariant(Step)"
           list="@(ShowTicks && Step is not null ? _listId : null)"
           disabled="@(ParentDisabled | Disabled)"
           style="@(ShowTicks && Step is not null ? $"--tick-count:{GetTickCount()}; " : "") @RangeStyle"
           @attributes="Attributes"
           @bind="Value"
           @oninput="OnValueChanged">
    <label class="label-txt-win @GetComponentLabelClass()"
           disabled="@(ParentDisabled | Disabled)">
        @HighLabel
    </label>

    @if (ShowTicks && Step is not null)
    {
        <datalist id="@_listId">
            @foreach (var tick in GetTicks())
            {
                <option value="@tick"></option>
            }
        </datalist>
    }
</div>