@namespace Blazor.WinOld.Components

@inherits WinOldComponentBase

<fieldset class="frame-win @GetComponentClass() @Class"
          style="@Style"
          disabled="@Disabled"
          @attributes="Attributes">
    @if (!string.IsNullOrWhiteSpace(Label))
    {
        <legend>@Label</legend>
    }
                        
    <CascadingValue Name="Disabled" Value="@Disabled">
        @ChildContent
    </CascadingValue>

</fieldset>